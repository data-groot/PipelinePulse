# PipelinePulse — Environment Variables
# Copy this file to .env and fill in real values

# ── Database ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pipelinepulse
DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/pipelinepulse

# ── Backend ────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Airflow ────────────────────────────────────────────
AIRFLOW_FERNET_KEY=your-fernet-key-generate-with-cryptography-fernet
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:changeme@postgres:5432/airflow

# ── Pipeline API Keys ──────────────────────────────────
OPENWEATHER_API_KEY=your-openweathermap-api-key
GITHUB_TOKEN=your-github-personal-access-token

# ── dbt ────────────────────────────────────────────────
DBT_HOST=postgres
DBT_USER=postgres
DBT_PASSWORD=changeme
DBT_DBNAME=pipelinepulse

# ── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
